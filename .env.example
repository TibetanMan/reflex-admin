# Environment Configuration
# ========================
# For local development: use localhost/127.0.0.1
# For Docker deployment: deploy.sh auto-generates this file
#   - DATABASE_URL uses 'postgres' (container name) instead of localhost
#   - REDIS_URL uses 'redis' (container name) instead of localhost
#   - DB_PASSWORD is auto-generated
#   - REDIS_PASSWORD is auto-generated
#   - SECRET_KEY is auto-generated
#   - BOT_TOKEN is NOT required in deploy.sh; configure bot token in admin panel

# App
APP_NAME=Digital Goods Platform
DEBUG=true

# Database (PostgreSQL)
# For local: use 127.0.0.1; For Docker: deploy.sh sets 'postgres'
DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/reflex
DB_PASSWORD=replace-with-strong-db-password

# Redis
# For local: configure redis auth to match REDIS_PASSWORD.
# For Docker: deploy.sh sets both REDIS_PASSWORD and REDIS_URL.
REDIS_PASSWORD=replace-with-strong-redis-password
REDIS_URL=redis://:replace-with-strong-redis-password@localhost:6379/0
# Runtime policy:
# - Application startup enforces DB-backed repositories.
# - "memory" backend is supported only for explicit test injection.
# Keep both values as "db" for normal runs.
EXPORT_TASK_BACKEND=db
PUSH_QUEUE_BACKEND=db

# Telegram Bot
# Managed in admin panel bot records for production deployment.
BOT_TOKEN=

# USDT Payment (TronGrid)
TRONGRID_API_KEY=your_trongrid_api_key
USDT_CONTRACT_ADDRESS=TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t

# Security
SECRET_KEY=your-secret-key-change-in-production-make-it-long-and-random
# Required at runtime: must be strong and non-default (startup fails otherwise)
SUPER_ADMIN_PASSWORD=replace-with-strong-super-admin-password

# Bootstrap hardening
BOOTSTRAP_DEMO_DATA_ENABLED=0
BOOTSTRAP_PURGE_DEMO_DATA=1
